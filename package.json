{
  "name": "schema-flow",
  "version": "0.1.5",
  "description": "An enterprise-class Schema-driven dynamic form engine and visual builder based on Vue 3 and Ant Design Vue.",
  "type": "module",
  "private": false,
  "repository": "https://github.com/zxl7/components",
  "main": "dist/schema-flow.umd.cjs",
  "module": "dist/schema-flow.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/schema-flow.js",
      "require": "./dist/schema-flow.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "bugs": "https://github.com/zxl7/components/issues",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "typecheck": "vue-tsc --noEmit",
    "build": "vue-tsc --noEmit && vite build",
    "build:lib": "vue-tsc --declaration --emitDeclarationOnly --outDir dist/types && vite build --config vite.lib.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "ant-design-vue": "^4.2.6",
    "vue": "^3.5.21",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^8.0.0",
    "vue-tsc": "^3.1.5"
  }
}
